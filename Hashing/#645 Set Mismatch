class Solution:
    def findErrorNums(self, nums: List[int]) -> List[int]:
        seen = set()
        a,b = 0,0
        for i in nums:
            if i in seen:
                a = i
            else:
                seen.add(i)
        for i in range(1,len(nums)+1):
            if i not in seen:
                b = i
                break
        return a,b
        
