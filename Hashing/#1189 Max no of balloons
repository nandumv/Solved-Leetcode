class Solution:
    def maxNumberOfBalloons(self, text: str) -> int:
        c1,c2,c3,c4,c5 = 0,0,0,0,0
        for i in text:
            if i == 'b':
                c1 += 1
            elif i == 'a':
                c2 += 1
            elif i == 'l':
                c3 += 1
            elif i == 'o':
                c4 += 1
            elif i == 'n':
                c5 += 1
        c3 //= 2
        c4 //= 2
        return min(c1,c2,c3,c4,c5)


        
