class Solution:
    def isValid(self, s: str) -> bool:
        stack = []
        top = -1
        for i in s:
            if i == '(' or i == '[' or i =='{':
                stack.append(i)
                top += 1
            elif not stack:
                return False
            elif i == ')' and stack[top] == '(':
                top -= 1
                stack.pop()
            elif i == ']' and stack[top] == '[':
                top -= 1
                stack.pop()
            elif i == '}' and stack[top] == '{':
                top -= 1
                stack.pop()
            else:
                return False
        if top != -1:
            return False
        return True
